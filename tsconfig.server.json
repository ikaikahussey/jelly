{
	"extends": "./tsconfig.node.json",
	"compilerOptions": {
		"composite": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
		"types": ["./worker-configuration.d.ts"],
		"lib": ["ES2023"],
		"baseUrl": ".",
		"paths": {
			"shared/*": ["./shared/*"],
			"worker/*": ["./worker/*"],
			"@/*": ["./src/*"]
		}
	},
	"include": ["./server", "./worker", "./shared", "./worker-configuration.d.ts"],
	"exclude": ["**/__tests__/**/*", "**/*.test.ts"]
}
